# TokenSaver 环境变量配置

# 数据库（Neon PostgreSQL）
# 格式: postgresql://用户名:密码@主机地址/数据库名?sslmode=require
DATABASE_URL=postgresql://neondb_owner:你的密码@ep-patient-art-aprjrzrd-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT密钥（生成: openssl rand -hex 32）
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe支付（海外）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_TEAM_MONTHLY_PRICE_ID=price_xxx
STRIPE_TEAM_YEARLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_xxx
STRIPE_SUCCESS_URL=https://tokensaver.ai/dashboard?success=true
STRIPE_CANCEL_URL=https://tokensaver.ai/pricing?canceled=true

# 微信支付（国内）- 待配置
WECHAT_APP_ID=xxx
WECHAT_MCH_ID=xxx
WECHAT_API_KEY=xxx

# 前端API地址
NEXT_PUBLIC_API_URL=https://api.tokesave.com/api/v1

# Stripe回调URL
STRIPE_SUCCESS_URL=https://tokesave.com/dashboard?success=true
STRIPE_CANCEL_URL=https://tokesave.com/pricing?canceled=true

# Redis（可选，用于缓存和限流）
REDIS_URL=redis://localhost:6379/0

# 邮件服务（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=xxx
SMTP_PASSWORD=xxx

# 监控（可选）
SENTRY_DSN=xxx
